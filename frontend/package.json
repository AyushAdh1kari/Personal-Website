{
    "name": "ayush-ai-frontend",
    "version": "1.0.0",
    "private": true,
    "description": "ayush.ai static personal website",
    "type": "commonjs",
    "scripts": {
        "dev": "serve . -l 5500",
        "build": "node scripts/build-static.mjs",
        "start": "serve dist -l 8080",
        "typecheck": "tsc --project tsconfig.json",
        "lint:js": "eslint app.js --max-warnings=0",
        "lint:css": "stylelint styles.css",
        "lint:html": "htmlhint \"*.html\"",
        "lint": "npm run lint:js && npm run lint:css && npm run lint:html",
        "format": "prettier --write \"**/*.{js,mjs,css,html,md,json,yml,yaml}\"",
        "format:check": "prettier --check \"**/*.{js,mjs,css,html,md,json,yml,yaml}\"",
        "check": "npm run typecheck && npm run lint && npm run format:check"
    },
    "engines": {
        "node": ">=20"
    },
    "devDependencies": {
        "@eslint/js": "^9.24.0",
        "eslint": "^9.24.0",
        "globals": "^17.5.0",
        "htmlhint": "^1.6.3",
        "prettier": "^3.5.3",
        "serve": "^14.2.4",
        "stylelint": "^16.17.0",
        "stylelint-config-standard": "^38.0.0",
        "typescript": "^5.8.3"
    }
}
