{
    "name": "ayush-ai-backend",
    "version": "1.0.0",
    "private": true,
    "description": "Backend API scaffold for ayush.ai",
    "type": "commonjs",
    "scripts": {
        "dev": "node --watch src/server.js",
        "start": "node src/server.js",
        "build": "node -e \"console.log('Backend build not required yet.')\"",
        "typecheck": "tsc --project tsconfig.json",
        "lint": "eslint \"src/**/*.js\" --max-warnings=0",
        "format": "prettier --write \"src/**/*.js\" \"*.json\"",
        "format:check": "prettier --check \"src/**/*.js\" \"*.json\"",
        "check": "npm run typecheck && npm run lint && npm run format:check"
    },
    "engines": {
        "node": ">=20"
    },
    "dependencies": {
        "cors": "^2.8.5",
        "dotenv": "^16.5.0",
        "express": "^4.21.2"
    },
    "devDependencies": {
        "@eslint/js": "^9.24.0",
        "@types/node": "^22.14.1",
        "eslint": "^9.24.0",
        "globals": "^17.6.0",
        "prettier": "^3.5.3",
        "typescript": "^5.8.3"
    }
}
